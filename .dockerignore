# Git
.git
.gitignore

# Build artifacts
msgvault
mimeshootout
bin/
dist/
/web/node_modules/
/web/dist/
!internal/web/dist/
!internal/web/dist/**

# IDE/editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Local data (should not be in image)
*.db
*.db-journal
*.db-wal
*.db-shm
tokens/
attachments/
analytics/

# Sensitive config files (prevent secrets in build context)
config.toml
client_secret*.json
oauth_client*.json
*.pem
*.key

# Environment files anywhere in the tree (web/.env.local would otherwise be
# copied into the frontend build stage and VITE_* values baked into artifacts)
**/.env
**/.env.*
**/.envrc
!**/.env.example

# Documentation (exclude most .md files but keep embedded assets)
*.md
!cmd/msgvault/cmd/quickstart.md
!go.mod
LICENSE

# CI/CD
.github/
.githooks/

# Nix
flake.nix
flake.lock
result

# Test data
testdata/
*_test.go
